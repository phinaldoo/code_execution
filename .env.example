# ============================================================
# Code Execution Service — Configuration
# ============================================================


APP_ENV=development
REQUIRE_AUTH=true
METRICS_AUTH_REQUIRED=true
API_KEYS=


# --- Gateway ---
GATEWAY_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
USE_DOCKER_DEFAULT_SECCOMP=true
# If you disable Docker's RuntimeDefault seccomp policy, point this at a file
# path that exists on the Docker daemon host. The checked-in profile under
# ./security is only a source artifact; the daemon cannot read it from inside
# the gateway container.
# SECCOMP_PROFILE_DAEMON_PATH=/etc/docker/seccomp/code-execution.json
# Local development: use `docker compose --profile local-docker ...`
# Production: point this at a dedicated remote Docker daemon, not docker-proxy.
# This configures the gateway container only; do not set host-side DOCKER_HOST
# to docker-proxy because that name exists only inside the Compose network.
GATEWAY_DOCKER_HOST=tcp://docker-proxy:2375
REDIS_URL=redis://redis:6379/0
REQUIRE_SHARED_STATE=true
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_HEALTH_CHECK_INTERVAL=30


# --- Sandbox Limits ---
SANDBOX_IMAGE=code-sandbox:latest
MAX_REQUEST_BODY_SIZE=33554432
MAX_CONCURRENT_EXECUTIONS=10
MAX_ACTIVE_SESSIONS=100
MAX_CONTAINERS_PER_PRINCIPAL=3
CONTAINER_CREATE_GUARD_TIMEOUT=30
DEFAULT_TIMEOUT=30
MAX_TIMEOUT=120
CONTAINER_RATE_LIMIT_REQUESTS_PER_WINDOW=10
CONTAINER_RATE_LIMIT_WINDOW_SECONDS=60
SANDBOX_MEM_LIMIT=512m
SANDBOX_TMP_ROOT_SIZE=512m
SANDBOX_CPU_PERIOD=100000
SANDBOX_CPU_QUOTA=100000
SANDBOX_PIDS_LIMIT=256
SANDBOX_SHM_SIZE=128m
SANDBOX_HOME_TMPFS_SIZE=256m
SANDBOX_UID=10001
SANDBOX_GID=10001
SANDBOX_READ_ONLY_ROOTFS=true
# Safe defaults for untrusted workloads — opt in to risky features explicitly.
ALLOW_PIP_INSTALLS=false

# --- Network ---
# "bridge" = internet access enabled
# "none"   = no network access (safe default for untrusted workloads)
SANDBOX_NETWORK_MODE=none

# Allow copying .env_sandbox into a sandbox only when the client explicitly
# requests it during container creation.
ALLOW_SANDBOX_ENV_INJECTION=false
