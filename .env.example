# ============================================================
# Code Execution Service - Configuration
# ============================================================


# --- Core ---
APP_ENV=development
GATEWAY_PORT=8000
LOG_LEVEL=INFO
ENABLE_DOCS=false
# Set PUBLIC_BETA_MODE=true, or APP_ENV=public_beta, before exposing this
# to arbitrary untrusted beta users. Public beta mode rejects risky sandbox
# features and requires a stronger runtime such as gVisor/runsc or Kata.
PUBLIC_BETA_MODE=false

# --- Authentication ---
REQUIRE_AUTH=true
METRICS_AUTH_REQUIRED=true
API_KEYS=
# API_KEY is accepted as a legacy single-key fallback when API_KEYS is empty.
# API_KEY=
# JWT auth is optional. When JWT_SECRET is set, Bearer tokens are first
# validated as JWTs and then as static API keys if static keys are configured.
# JWT_SECRET=
JWT_ALGORITHMS=HS256
# JWT_ISSUER=
# JWT_AUDIENCE=
JWT_TENANT_CLAIM=tenant_id

# --- CORS ---
ENABLE_CORS=true
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_METHODS=GET,POST,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID,X-API-Key
CORS_ALLOW_CREDENTIALS=true

# --- Docker and state ---
USE_DOCKER_DEFAULT_SECCOMP=true
DOCKER_CLIENT_TIMEOUT=30
# Optional stronger isolation runtime configured on the Docker daemon host.
# Examples: runsc for gVisor, kata-runtime for Kata Containers.
SANDBOX_RUNTIME=
STRONG_SANDBOX_RUNTIMES=runsc,kata,kata-runtime,io.containerd.runsc.v1,io.containerd.kata.v2
REQUIRE_STRONG_SANDBOX_ISOLATION=false
# If you disable Docker's RuntimeDefault seccomp policy, point this at a file
# path that exists on the Docker daemon host. The checked-in profile under
# ./security is only a source artifact; the daemon cannot read it from inside
# the gateway container.
# SECCOMP_PROFILE_DAEMON_PATH=/etc/docker/seccomp/code-execution.json
# Local development: use `docker compose --profile local-docker ...`
# Production: point this at a dedicated remote Docker daemon, not docker-proxy.
# This configures the gateway container only; do not set host-side DOCKER_HOST
# to docker-proxy because that name exists only inside the Compose network.
GATEWAY_DOCKER_HOST=tcp://docker-proxy:2375
REDIS_URL=redis://redis:6379/0
REQUIRE_SHARED_STATE=true
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_HEALTH_CHECK_INTERVAL=30


# --- Sandbox runtime and limits ---
SANDBOX_IMAGE=code-sandbox:latest
SANDBOX_USER=sandbox
MAX_REQUEST_BODY_SIZE=33554432
MAX_INPUT_FILES=10
MAX_INPUT_FILE_SIZE=5242880
MAX_INPUT_TOTAL_SIZE=20971520
MAX_FILE_NAME_LENGTH=128
MAX_CONCURRENT_EXECUTIONS=10
MAX_ACTIVE_SESSIONS=100
MAX_CONTAINERS_PER_PRINCIPAL=3
CONTAINER_CREATE_GUARD_TIMEOUT=30
SESSION_TIMEOUT_SECONDS=1200
MAX_SESSION_LIFETIME_SECONDS=3600
MAX_EXECUTIONS_PER_SESSION=100
DEFAULT_TIMEOUT=30
MAX_TIMEOUT=120
RATE_LIMIT_REQUESTS_PER_WINDOW=30
RATE_LIMIT_WINDOW_SECONDS=60
CONTAINER_RATE_LIMIT_REQUESTS_PER_WINDOW=10
CONTAINER_RATE_LIMIT_WINDOW_SECONDS=60
SANDBOX_MEM_LIMIT=512m
SANDBOX_TMP_ROOT_SIZE=512m
SANDBOX_CPU_PERIOD=100000
SANDBOX_CPU_QUOTA=100000
SANDBOX_PIDS_LIMIT=256
SANDBOX_SHM_SIZE=128m
SANDBOX_HOME_TMPFS_SIZE=256m
SANDBOX_UID=10001
SANDBOX_GID=10001
SANDBOX_READ_ONLY_ROOTFS=true
# Safe defaults for untrusted workloads - opt in to risky features explicitly.
ALLOW_PIP_INSTALLS=false
MAX_PIP_PACKAGES=5
MAX_PIP_PACKAGE_NAME_LENGTH=64
FILE_PROVISION_TIMEOUT=30

# --- Slide presentation rendering ---
# Uses the same sandbox image and Playwright browser cache as code execution.
SLIDE_RENDERING_VERSION=v1
# Set SLIDE_RENDERING_VERSION=v2 to use the editable beta renderer ported from
# slide_presentation_renderer#1.
RENDER_TIMEOUT_SECONDS=180
RENDER_QUEUE_TIMEOUT_MS=500
PAGE_LOAD_TIMEOUT_MS=30000
MAX_CONCURRENT_RENDERS=2
RENDER_RATE_LIMIT_REQUESTS_PER_WINDOW=10
RENDER_RATE_LIMIT_WINDOW_SECONDS=60
RENDER_MAX_REQUEST_BODY_BYTES=180000000
RENDER_MAX_HTML_CHARS=2000000
RENDER_MAX_INPUT_FILES=32
RENDER_MAX_SLIDES=200
RENDER_MAX_ASSET_BYTES=25000000
RENDER_MAX_TOTAL_ASSET_BYTES=120000000
RENDER_MAX_OUTPUT_BYTES=220000000
RENDER_SANDBOX_MEM_LIMIT=2g
RENDER_SANDBOX_CPU_PERIOD=100000
RENDER_SANDBOX_CPU_QUOTA=200000
RENDER_SANDBOX_PIDS_LIMIT=512
RENDER_SANDBOX_TMP_ROOT_SIZE=1g
RENDER_SANDBOX_SHM_SIZE=512m
RENDER_SANDBOX_HOME_TMPFS_SIZE=256m

# --- Network ---
# "bridge" = internet access enabled
# "none"   = no network access (safe default for untrusted workloads)
SANDBOX_NETWORK_MODE=none

# Allow copying .env_sandbox into a sandbox only when the client explicitly
# requests it during container creation.
ALLOW_SANDBOX_ENV_INJECTION=false
SANDBOX_ENV_TARGET_PATH=/home/sandbox/.env
# In Compose, this is overridden to /etc/code-execution/.env_sandbox inside
# the gateway container.
# SANDBOX_ENV_SOURCE_PATH=.env_sandbox

# --- Build ---
PYTHON_BASE_IMAGE=python:3.12-slim-bookworm@sha256:dba9a3ac4914b5ae6f790188ff39267e46e0087fa0f4713592b5d32350edb5ef
