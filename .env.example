# ============================================================
# Code Execution Service — Configuration
# ============================================================


# API_KEY=your-secret-key-here  # Uncomment to enable Bearer token protection


# --- Gateway ---
GATEWAY_PORT=8000
LOG_LEVEL=INFO


# --- Sandbox Limits ---
SANDBOX_IMAGE=code-sandbox:latest
MAX_CONCURRENT_EXECUTIONS=10
DEFAULT_TIMEOUT=30
MAX_TIMEOUT=120
SANDBOX_MEM_LIMIT=512m
SANDBOX_CPU_PERIOD=100000
SANDBOX_CPU_QUOTA=100000
SANDBOX_PIDS_LIMIT=256
SANDBOX_TMPFS_SIZE=100m
SANDBOX_MPL_CACHE_TMPFS_SIZE=32m
SANDBOX_MISC_TMPFS_SIZE=128m
SANDBOX_SHM_SIZE=128m

# --- Network ---
# "bridge" = internet access enabled (default)
# "none"   = no network access
SANDBOX_NETWORK_MODE=bridge
